BACKEND_BASE_URL=http://localhost:8000
BACKEND_QUERY_PATH=/query
HEALTH_PATH=/health
REQUEST_TIMEOUT_SECONDS=90
APP_TITLE=HR Compliance RAG Assistant
LOG_LEVEL=INFO

DEFAULT_TOP_K_RETRIEVAL=8
DEFAULT_TOP_K_CONTEXT=4
SHOW_CITATIONS_DEFAULT=true

EMBEDDING_MODEL_NAME=sentence-transformers/all-mpnet-base-v2
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
LLM_MODEL_NAME=google/flan-t5-base

REPO_ROOT=./hr-compliance-rag
VECTORSTORE_DIR=./hr-compliance-rag/vectorstore
